{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "АВТОГЕНЕРИРОВАН из security/dangerous-commands.md. НЕ редактировать руками — изменения будут перезаписаны. Правь источник в security/dangerous-commands.md.",
  "permissions": {
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git push * main*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fdx*)",
      "Bash(git commit *--no-verify*)",
      "Bash(git push *--no-verify*)",
      "Bash(git tag -d v*)",
      "Bash(git push * --delete *v*)",
      "Bash(git push * :refs/tags/v*)",
      "Bash(git update-ref -d refs/tags/v*)",
      "Bash(git tag -f v*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git rebase -i*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sudo *)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(sudo *)",
      "Bash(chmod 777*)",
      "Bash(chmod -R 777*)",
      "Bash(eval *)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(:(){:|:&};:)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.p12)",
      "Read(*.pfx)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(id_ecdsa)",
      "Read(~/.ssh/*_rsa)",
      "Read(~/.aws/credentials)",
      "Read(~/.kube/config)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset*)",
      "Bash(git rebase*)",
      "Bash(git rebase origin/main*)",
      "Bash(git merge*)",
      "Bash(git checkout -- *)",
      "Bash(git tag*)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(npm publish*)",
      "Bash(cargo publish*)",
      "Bash(twine upload*)",
      "Bash(gh release create*)",
      "Bash(pip install*)",
      "Bash(npm install*)",
      "Bash(brew install*)",
      "Bash(apt-get install*)",
      "Bash(docker run*)",
      "Bash(docker rmi*)",
      "Bash(kubectl delete*)",
      "Bash(terraform destroy*)",
      "Bash(terraform apply*)"
    ]
  },
  "_skills_note": "Skills этого проекта — в .claude/skills/ (тонкие обёртки над playbooks/). Установка глобальных skills — в personal config (~/.claude/), не сюда.",
  "_mcp_servers_note": "MCP-серверы (только context7 по умолчанию) подключаются в personal config либо через `claude mcp add`. Сюда не добавляем — это меняет окружение коллабораторов."
}
